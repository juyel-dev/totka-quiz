<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp" android:gravity="center_horizontal">

        <TextView android:id="@+id/tvStep" android:text="Step 2 / 3 — Profile"
            android:textColor="@color/accent_indigo" android:textSize="12sp"
            android:textAllCaps="true" android:layout_marginTop="48dp" android:layout_marginBottom="4dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginBottom="24dp"/>

        <!-- Profile Picture -->
        <de.hdodenhof.circleimageview.CircleImageView android:id="@+id/imgProfile"
            android:layout_width="100dp" android:layout_height="100dp"
            android:src="@drawable/ic_avatar"
            app:civ_border_width="3dp" app:civ_border_color="@color/accent_indigo"
            android:layout_gravity="center" android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton android:id="@+id/btnPickPhoto"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="📷 Choose Photo" android:textColor="@color/accent_cyan"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:layout_marginBottom="24dp"/>

        <!-- Full Name -->
        <com.google.android.material.textfield.TextInputLayout style="@style/TotkaInput"
            android:hint="Full Name" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="24dp">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etFullName"
                android:inputType="textPersonName" android:textColor="@color/text_primary"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton android:id="@+id/btnNext"
            style="@style/BtnPrimary" android:text="Next →"
            android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginBottom="8dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btnBack"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="← Back" android:textColor="@color/text_secondary"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </LinearLayout>
</ScrollView>
