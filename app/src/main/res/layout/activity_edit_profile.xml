<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_dark">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:padding="8dp">
        <ImageButton android:id="@+id/btn_edit_back"
            android:layout_width="40dp" android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_close_clear_cancel"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="প্রোফাইল এডিট"
            android:textColor="@color/text_primary" android:textSize="18sp"
            android:textStyle="bold" android:paddingStart="8dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText android:id="@+id/et_edit_username" android:layout_width="match_parent"
                android:layout_height="52dp" android:hint="Username"
                android:background="@drawable/bg_input" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" android:paddingHorizontal="14dp"
                android:layout_marginBottom="10dp"/>
            <EditText android:id="@+id/et_edit_bio" android:layout_width="match_parent"
                android:layout_height="80dp" android:hint="Bio" android:inputType="textMultiLine"
                android:gravity="top|start" android:background="@drawable/bg_input"
                android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
                android:paddingHorizontal="14dp" android:layout_marginBottom="10dp"/>
            <EditText android:id="@+id/et_edit_fav" android:layout_width="match_parent"
                android:layout_height="52dp" android:hint="Favourite Subject"
                android:background="@drawable/bg_input" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" android:paddingHorizontal="14dp"
                android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Social Links" android:textColor="@color/text_secondary"
                android:textSize="12sp" android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/et_edit_facebook" android:layout_width="match_parent"
                android:layout_height="48dp" android:hint="Facebook URL"
                android:background="@drawable/bg_input" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" android:paddingHorizontal="14dp"
                android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/et_edit_instagram" android:layout_width="match_parent"
                android:layout_height="48dp" android:hint="Instagram URL"
                android:background="@drawable/bg_input" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" android:paddingHorizontal="14dp"
                android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/et_edit_youtube" android:layout_width="match_parent"
                android:layout_height="48dp" android:hint="YouTube URL"
                android:background="@drawable/bg_input" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" android:paddingHorizontal="14dp"
                android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/et_edit_telegram" android:layout_width="match_parent"
                android:layout_height="48dp" android:hint="Telegram @username"
                android:background="@drawable/bg_input" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" android:paddingHorizontal="14dp"
                android:layout_marginBottom="20dp"/>

            <ProgressBar android:id="@+id/edit_progress" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:layout_gravity="center"
                android:visibility="gone" android:indeterminateTint="@color/brand_primary"/>

            <Button android:id="@+id/btn_save_profile" style="@style/TotkaButton"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="@string/save_changes"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>