<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_dark" android:padding="16dp">

    <!-- Loading overlay -->
    <ProgressBar android:id="@+id/quiz_loading"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:visibility="gone"
        android:indeterminateTint="@color/brand_primary"/>

    <!-- Top bar: progress + timer + bookmark -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
        <TextView android:id="@+id/tv_progress"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="1 / 10"
            android:textColor="@color/text_secondary" android:textSize="13sp"/>
        <TextView android:id="@+id/tv_timer"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="00:00" android:textColor="@color/brand_accent"
            android:textSize="14sp" android:textStyle="bold" android:layout_marginEnd="8dp"/>
        <ImageButton android:id="@+id/btn_bookmark"
            android:layout_width="36dp" android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/btn_star_big_off"/>
    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar android:id="@+id/quiz_progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent" android:layout_height="6dp"
        android:progressTint="@color/brand_primary"
        android:max="10" android:progress="1"
        android:layout_marginBottom="16dp"/>

    <!-- Question card -->
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView android:id="@+id/tv_question"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_card" android:padding="16dp"
                android:textColor="@color/text_primary" android:textSize="15sp"
                android:lineSpacingMultiplier="1.4" android:layout_marginBottom="16dp"/>

            <!-- Options -->
            <Button android:id="@+id/btn_opt_a" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="@drawable/bg_input"
                android:textColor="@color/text_primary" android:gravity="start|center_vertical"
                android:paddingHorizontal="16dp" android:paddingVertical="14dp"
                android:textSize="14sp" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btn_opt_b" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="@drawable/bg_input"
                android:textColor="@color/text_primary" android:gravity="start|center_vertical"
                android:paddingHorizontal="16dp" android:paddingVertical="14dp"
                android:textSize="14sp" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btn_opt_c" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="@drawable/bg_input"
                android:textColor="@color/text_primary" android:gravity="start|center_vertical"
                android:paddingHorizontal="16dp" android:paddingVertical="14dp"
                android:textSize="14sp" android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btn_opt_d" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="@drawable/bg_input"
                android:textColor="@color/text_primary" android:gravity="start|center_vertical"
                android:paddingHorizontal="16dp" android:paddingVertical="14dp"
                android:textSize="14sp" android:layout_marginBottom="12dp"/>

            <!-- Explanation -->
            <LinearLayout android:id="@+id/layout_explanation"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_card"
                android:padding="14dp" android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💡 ব্যাখ্যা" android:textColor="@color/brand_accent"
                    android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tv_explanation"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Navigation buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginTop="8dp">
        <Button android:id="@+id/btn_prev" style="@style/TotkaButton"
            android:layout_width="56dp" android:layout_height="48dp"
            android:text="←" android:backgroundTint="@color/bg_card" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btn_next" style="@style/TotkaButton"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:text="পরবর্তী →"/>
        <Button android:id="@+id/btn_submit_quiz" style="@style/TotkaButton"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:text="জমা দিন ✓"
            android:visibility="gone" android:backgroundTint="@color/correct"/>
    </LinearLayout>
</LinearLayout>