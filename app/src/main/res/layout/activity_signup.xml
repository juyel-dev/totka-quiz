<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_page_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Page 1 / 3"
            android:textColor="@color/brand_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="নতুন অ্যাকাউন্ট"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ══ PAGE 1 ══ -->
    <ScrollView
        android:id="@+id/page_1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/page1_title" android:textColor="@color/text_primary"
                android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/page1_sub" android:textColor="@color/text_secondary"
                android:textSize="13sp" android:layout_marginBottom="24dp"/>

            <EditText android:id="@+id/et_signup_gmail"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:hint="Gmail / Phone" android:inputType="textEmailAddress"
                android:background="@drawable/bg_input" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp"/>

            <EditText android:id="@+id/et_signup_password"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:hint="Password" android:inputType="textPassword"
                android:background="@drawable/bg_input" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" android:paddingHorizontal="16dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- ══ PAGE 2 ══ -->
    <ScrollView
        android:id="@+id/page_2"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/page2_title" android:textColor="@color/text_primary"
                android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/page2_sub" android:textColor="@color/text_secondary"
                android:textSize="13sp" android:layout_marginBottom="24dp"/>

            <ImageView android:id="@+id/img_avatar"
                android:layout_width="100dp" android:layout_height="100dp"
                android:src="@mipmap/ic_launcher_round"
                android:layout_marginBottom="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ছবিতে ক্লিক করো" android:textColor="@color/brand_secondary"
                android:textSize="12sp" android:layout_marginBottom="20dp"/>

            <EditText android:id="@+id/et_full_name"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:hint="Full Name" android:inputType="textPersonName"
                android:background="@drawable/bg_input" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" android:paddingHorizontal="16dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- ══ PAGE 3 ══ -->
    <ScrollView
        android:id="@+id/page_3"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/page3_title" android:textColor="@color/text_primary"
                android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/page3_sub" android:textColor="@color/text_secondary"
                android:textSize="13sp" android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Board" android:textColor="@color/text_secondary" android:textSize="12sp"/>
            <Spinner android:id="@+id/spin_board"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:background="@drawable/bg_input" android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Class" android:textColor="@color/text_secondary" android:textSize="12sp"/>
            <Spinner android:id="@+id/spin_class"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:background="@drawable/bg_input" android:layout_marginBottom="12dp"/>

            <EditText android:id="@+id/et_username"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:hint="Username (@yourname)" android:inputType="textNoSuggestions"
                android:background="@drawable/bg_input" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp"/>

            <EditText android:id="@+id/et_bio"
                android:layout_width="match_parent" android:layout_height="80dp"
                android:hint="Bio (optional)" android:inputType="textMultiLine"
                android:gravity="top|start" android:background="@drawable/bg_input"
                android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
                android:paddingHorizontal="16dp" android:layout_marginBottom="12dp"/>

            <EditText android:id="@+id/et_fav_subject"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:hint="Favourite Subject" android:background="@drawable/bg_input"
                android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
                android:paddingHorizontal="16dp" android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Social Links (optional)" android:textColor="@color/text_secondary"
                android:textSize="12sp" android:layout_marginBottom="8dp"/>

            <EditText android:id="@+id/et_facebook" android:layout_width="match_parent"
                android:layout_height="48dp" android:hint="Facebook URL"
                android:background="@drawable/bg_input" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" android:paddingHorizontal="16dp"
                android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/et_instagram" android:layout_width="match_parent"
                android:layout_height="48dp" android:hint="Instagram URL"
                android:background="@drawable/bg_input" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" android:paddingHorizontal="16dp"
                android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/et_youtube" android:layout_width="match_parent"
                android:layout_height="48dp" android:hint="YouTube URL"
                android:background="@drawable/bg_input" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" android:paddingHorizontal="16dp"
                android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/et_telegram" android:layout_width="match_parent"
                android:layout_height="48dp" android:hint="Telegram @username"
                android:background="@drawable/bg_input" android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" android:paddingHorizontal="16dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom navigation -->
    <ProgressBar android:id="@+id/signup_progress"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:visibility="gone"
        android:indeterminateTint="@color/brand_primary"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp"
        android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">

        <Button android:id="@+id/btn_back_page" style="@style/TotkaButton"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:text="@string/back"
            android:backgroundTint="@color/bg_card" android:layout_marginEnd="8dp"/>

        <Button android:id="@+id/btn_next_page" style="@style/TotkaButton"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="2" android:text="@string/next"/>

        <Button android:id="@+id/btn_submit" style="@style/TotkaButton"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="2" android:text="@string/submit"
            android:visibility="gone"/>
    </LinearLayout>
</LinearLayout>
