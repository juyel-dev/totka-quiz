<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_dark">

    <!-- Toolbar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:padding="8dp">
        <ImageButton android:id="@+id/btn_profile_back"
            android:layout_width="40dp" android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Back"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="প্রোফাইল"
            android:textColor="@color/text_primary" android:textSize="18sp"
            android:textStyle="bold" android:paddingStart="8dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp" android:gravity="center_horizontal">

            <!-- Avatar -->
            <ImageView android:id="@+id/img_profile_avatar"
                android:layout_width="90dp" android:layout_height="90dp"
                android:src="@mipmap/ic_launcher_round"
                android:layout_marginBottom="8dp"/>

            <TextView android:id="@+id/tv_profile_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Name" android:textColor="@color/text_primary"
                android:textSize="22sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tv_profile_username"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@username" android:textColor="@color/brand_secondary"
                android:textSize="14sp" android:layout_marginBottom="8dp"/>
            <TextView android:id="@+id/tv_profile_bio"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/text_secondary" android:textSize="13sp"
                android:gravity="center" android:layout_marginBottom="20dp"/>

            <!-- Info card -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_card" android:padding="16dp"
                android:orientation="vertical" android:layout_marginBottom="12dp">
                <TextView android:id="@+id/tv_profile_board" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/text_primary"
                    android:textSize="14sp" android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tv_profile_class" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/text_primary"
                    android:textSize="14sp" android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tv_profile_fav" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/text_primary"
                    android:textSize="14sp" android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tv_profile_streak" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/brand_accent"
                    android:textSize="14sp" android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tv_profile_joined" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Social links -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_card" android:padding="16dp"
                android:orientation="vertical" android:layout_marginBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Social Links" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tv_social_fb" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/brand_primary"
                    android:textSize="14sp" android:paddingVertical="4dp"/>
                <TextView android:id="@+id/tv_social_ig" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/brand_primary"
                    android:textSize="14sp" android:paddingVertical="4dp"/>
                <TextView android:id="@+id/tv_social_yt" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/brand_primary"
                    android:textSize="14sp" android:paddingVertical="4dp"/>
                <TextView android:id="@+id/tv_social_tg" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/brand_primary"
                    android:textSize="14sp" android:paddingVertical="4dp"/>
            </LinearLayout>

            <Button android:id="@+id/btn_edit_profile" style="@style/TotkaButton"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="@string/edit_profile" android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btn_logout" style="@style/TotkaButton"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="লগআউট" android:backgroundTint="@color/wrong"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>