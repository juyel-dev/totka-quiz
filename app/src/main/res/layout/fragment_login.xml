<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center"
        android:padding="24dp" android:minHeight="600dp">

        <TextView android:text="⚡" android:textSize="56sp" android:gravity="center"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>
        <TextView android:text="Totka Quiz" android:textSize="28sp" android:textStyle="bold"
            android:textColor="@color/text_primary" android:gravity="center"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <TextView android:text="আবার স্বাগতম! 👋" android:textSize="13sp"
            android:textColor="@color/text_secondary" android:gravity="center"
            android:layout_marginBottom="32dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <!-- Gmail -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/TotkaInput" android:hint="Gmail / Phone Number"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etGmail"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="textEmailAddress" android:textColor="@color/text_primary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/TotkaInput" android:hint="Password"
            app:endIconMode="password_toggle"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="textPassword" android:textColor="@color/text_primary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <ProgressBar android:id="@+id/progressBar" android:visibility="gone"
            android:indeterminateTint="@color/accent_indigo"
            android:layout_width="32dp" android:layout_height="32dp"
            android:layout_gravity="center" android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin" style="@style/BtnPrimary"
            android:text="Login" android:layout_width="match_parent"
            android:layout_height="56dp" android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoSignup"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="অ্যাকাউন্ট নেই? Sign Up করো"
            android:textColor="@color/accent_indigo"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>
