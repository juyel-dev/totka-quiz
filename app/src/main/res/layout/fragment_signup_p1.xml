<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp" android:gravity="center_horizontal">

        <TextView android:id="@+id/tvStep" android:text="Step 1 / 3 — Account Info"
            android:textColor="@color/accent_indigo" android:textSize="12sp"
            android:textAllCaps="true" android:letterSpacing="0.1"
            android:layout_marginTop="48dp" android:layout_marginBottom="4dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginBottom="24dp"/>

        <TextView android:text="Account তৈরি করো" android:textSize="24sp" android:textStyle="bold"
            android:textColor="@color/text_primary" android:layout_marginBottom="24dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <com.google.android.material.textfield.TextInputLayout style="@style/TotkaInput"
            android:hint="Gmail or Phone Number"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etGmail"
                android:inputType="textEmailAddress" android:textColor="@color/text_primary"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout style="@style/TotkaInput"
            android:hint="Password (6+ characters)" app:endIconMode="password_toggle"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etPassword"
                android:inputType="textPassword" android:textColor="@color/text_primary"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout style="@style/TotkaInput"
            android:hint="Confirm Password" app:endIconMode="password_toggle"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etConfirmPassword"
                android:inputType="textPassword" android:textColor="@color/text_primary"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton android:id="@+id/btnNext"
            style="@style/BtnPrimary" android:text="Next →"
            android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginBottom="8dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btnBack"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="← Back to Login" android:textColor="@color/text_secondary"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </LinearLayout>
</ScrollView>
